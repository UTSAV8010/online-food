RewriteEngine On
ErrorDocument 404 /404.php

# Redirect old restro URLs
RewriteRule ^(?:frontend/)?restro(?:\.php)?/?$ /restaurant [R=302,L,NC,QSA]

# Redirect frontend URLs to clean URLs
RewriteCond %{THE_REQUEST} \s+/frontend/?(?:\s|\?) [NC]
RewriteRule ^frontend/?$ / [R=302,L,NC]

RewriteCond %{THE_REQUEST} \s+/frontend/([^\s?]+?)\.php(?:\s|\?) [NC]
RewriteRule ^frontend/(.+)\.php$ /$1 [R=302,L,NC,QSA]

# Redirect root .php URLs to extensionless URLs
RewriteCond %{THE_REQUEST} \s+/index\.php(?:\s|\?) [NC]
RewriteRule ^index\.php$ / [R=302,L,NC]

RewriteCond %{THE_REQUEST} \s+/([^/\s?]+)\.php(?:\s|\?) [NC]
RewriteCond %{DOCUMENT_ROOT}/frontend/%1.php -f
RewriteRule ^([^/]+)\.php$ /$1 [R=302,L,NC,QSA]

# Redirect panel .php URLs
RewriteCond %{THE_REQUEST} \s+/(admin|restro|delivery-boy)/([^/\s?]+)\.php(?:\s|\?) [NC]
RewriteCond %{DOCUMENT_ROOT}/%1/%2.php -f
RewriteRule ^(admin|restro|delivery-boy)/([^/]+)\.php$ /$1/$2 [R=302,L,NC,QSA]

# Reject invalid URLs
RewriteRule ^.+\.php/.*$ - [R=404,L,NC]

# Serve extensionless panel pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1/$2.php -f
RewriteRule ^(admin|restro|delivery-boy)/([^/]+)/?$ $1/$2.php [L,NC,QSA]

# Ignore existing project areas
RewriteCond %{REQUEST_URI} ^/(?:frontend|admin|restro|delivery-boy|database|images)(?:/|$) [NC]
RewriteRule ^ - [L]

# Allow direct access to existing files/folders
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Homepage
RewriteRule ^$ frontend/index.php [L]

# Frontend extensionless pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/frontend/$1.php -f
RewriteRule ^([^/]+)/?$ frontend/$1.php [L,NC,QSA]

# Frontend assets
RewriteRule ^(.+)$ frontend/$1 [L]